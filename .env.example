# Server Configuration
PORT=3001
NODE_ENV=production

# Frontend URL (update when deployed)
CLIENT_URL=http://localhost:5173

# JWT Secrets (generate strong random strings)
JWT_SECRET=your-super-secret-key-here-minimum-32-characters
JWT_REFRESH_SECRET=your-other-super-secret-key-here-minimum-32

# Admin Configuration
ADMIN_EMAILS=adminV11@gmail.com

# Email Verification (optional)
REQUIRE_EMAIL_VERIFICATION=false

# SMTP Configuration (optional, for email features)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@gmail.com
# SMTP_PASS=your-app-password
# FROM_EMAIL=your@gmail.com
# APP_URL=http://localhost:5173

